{
  "_pixelForgeExample": true,
  "_notes": [
    "Replace this file with a real ComfyUI API-format workflow JSON exported from the ComfyUI UI.",
    "In ComfyUI, enable developer options if needed, then use Save (API Format).",
    "Pixel Forge replaces these placeholders before submission: {{PROMPT}}, {{NEGATIVE_PROMPT}}, {{SEED}}, {{WIDTH}}, {{HEIGHT}}.",
    "Keep the workflow in ComfyUI API format with node ids as object keys.",
    "Your real workflow should include at least one image-saving output such as SaveImage."
  ],
  "_example_api_nodes": {
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{PROMPT}}",
        "clip": [
          "4",
          1
        ]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{NEGATIVE_PROMPT}}",
        "clip": [
          "4",
          1
        ]
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "{{WIDTH}}",
        "height": "{{HEIGHT}}",
        "batch_size": 1
      }
    },
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": "{{SEED}}",
        "steps": 20,
        "cfg": 7,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1,
        "model": [
          "4",
          0
        ],
        "positive": [
          "6",
          0
        ],
        "negative": [
          "7",
          0
        ],
        "latent_image": [
          "5",
          0
        ]
      }
    }
  }
}
